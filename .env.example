# Required
GEMINI_API_KEY=your_api_key_here

# Model and paths
MODEL_NAME=gemini-3.1-pro-preview
OUTPUT_DIR=outputs
CHECKPOINT_DIR=checkpoints

# API endpoint. Keep default if your original endpoint works.
GEMINI_API_BASE_URL=https://aiplatform.googleapis.com/v1/publishers/google/models

# Required for scripts/generate_2023_review.py if use_pdf=True
# Option A: direct GCS URI
GCS_URI=gs://your-bucket/23English.pdf

# Option B: compose GCS URI from bucket + object
# GCS_BUCKET_NAME=your-bucket
# PDF_OBJECT_NAME=23English.pdf
